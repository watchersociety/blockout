{
  "name": "blockout",
  "version": "5.0.0",
  "description": "Desktop previs tool for AI-native filmmaking — stage scenes, choreograph camera & character blocking with marks, export motion-reference packages for AI video generators.",
  "main": "out/main/index.js",
  "author": "Sam Wasserman",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "node ./node_modules/electron-vite/bin/electron-vite.js dev",
    "start": "node ./node_modules/electron-vite/bin/electron-vite.js preview",
    "build": "node ./node_modules/electron-vite/bin/electron-vite.js build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "npm run build && playwright test tests/e2e/smoke.spec.ts",
    "e2e": "npm run build && playwright test",
    "package:dir": "npm run build && electron-builder --mac --dir --config electron-builder.yml",
    "package": "npm run build && electron-builder --mac --config electron-builder.yml",
    "package:all": "npm run build && electron-builder -mwl --config electron-builder.yml"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "three": "^0.170.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^6.0.0-beta.1",
    "eslint": "^9.39.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.2.0"
  }
}
